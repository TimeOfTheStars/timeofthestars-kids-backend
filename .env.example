# Async SQLAlchemy URL (обязательно драйвер asyncpg)
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# VK: токен сообщества (group token) для отправки уведомлений (messages.send)
VK_TOKEN=your_vk_access_token

# VK: токен для чтения обсуждений (board.getComments). Подходит:
#  - сервисный токен приложения VK (vk.com/dev → Мои приложения → Сервисный ключ доступа), либо
#  - user access token (standalone-приложение).
# Group/community токен сюда не подойдёт — VK вернёт ошибку 27.
# Если не задан — будет попытка использовать VK_TOKEN.
VK_READ_TOKEN=your_vk_service_or_user_token

# JWT для кабинета (минимум 32 символа)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Первый админ при пустой таблице admin_users (потом удалите из .env в проде)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change_me_strong_password
# Опционально: сразу привязать VK user_id к первому админу
# ADMIN_BOOTSTRAP_VK_USER_ID=123456789

# Источник отзывов: VK обсуждение (topic) в сообществе
VK_REVIEWS_GROUP_ID=125696800
VK_REVIEWS_TOPIC_ID=56616420

# Опционально
VK_API_VERSION=5.199
HTTP_TIMEOUT_SECONDS=15
VK_RETRY_ATTEMPTS=3
VK_RETRY_BACKOFF_SECONDS=0.5
SQLALCHEMY_ECHO=false
LOG_LEVEL=INFO
JWT_EXPIRE_MINUTES=1440
