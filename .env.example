# Async SQLAlchemy URL (обязательно драйвер asyncpg)
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# VK: user access token с правом messages (список получателей — в кабинете у каждого админа, поле vk_user_id)
VK_TOKEN=your_vk_access_token

# JWT для кабинета (минимум 32 символа)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Первый админ при пустой таблице admin_users (потом удалите из .env в проде)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change_me_strong_password
# Опционально: сразу привязать VK user_id к первому админу
# ADMIN_BOOTSTRAP_VK_USER_ID=123456789

# Опционально
VK_API_VERSION=5.199
HTTP_TIMEOUT_SECONDS=15
VK_RETRY_ATTEMPTS=3
VK_RETRY_BACKOFF_SECONDS=0.5
SQLALCHEMY_ECHO=false
LOG_LEVEL=INFO
JWT_EXPIRE_MINUTES=1440
